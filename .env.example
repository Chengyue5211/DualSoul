# DualSoul Configuration
# Copy this file to .env and customize

# JWT secret (auto-generated if not set, but won't persist across restarts)
DUALSOUL_JWT_SECRET=change-me-to-a-random-string

# Database path
DUALSOUL_DATABASE_PATH=./dualsoul.db

# AI Backend (OpenAI-compatible API)
# Leave empty to run without AI (twins will use template responses)
DUALSOUL_AI_BASE_URL=
DUALSOUL_AI_KEY=
DUALSOUL_AI_MODEL=gpt-3.5-turbo

# Server
DUALSOUL_HOST=0.0.0.0
DUALSOUL_PORT=8000
