.profile-page { padding-bottom: 120rpx; }

/* 双头像卡片 */
.dual-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 50rpx 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.dual-avatar-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 30rpx;
}

.avatar-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.6;
  position: relative;
}
.avatar-block.active { opacity: 1; }

.avatar-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}
.avatar-circle.real {
  background: rgba(76,175,80,0.3);
  border: 4rpx solid #4CAF50;
}
.avatar-circle.twin {
  background: rgba(156,39,176,0.3);
  border: 4rpx solid #CE93D8;
}
.avatar-emoji { font-size: 52rpx; }
.avatar-label { font-size: 24rpx; }

.active-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4CAF50;
  position: absolute;
  top: 0;
  right: 10rpx;
}

.switch-center {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.switch-icon { font-size: 48rpx; }
.switch-hint { font-size: 20rpx; opacity: 0.7; }

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

/* 设置区域 */
.section {
  background: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.setting-item { margin-bottom: 24rpx; }
.setting-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}
.setting-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.btn-save {
  background: #667eea;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  margin-top: 10rpx;
}
.btn-save::after { border: none; }

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 28rpx; color: #333; }
.info-value { font-size: 28rpx; color: #999; }
.info-arrow { font-size: 36rpx; color: #ccc; }
