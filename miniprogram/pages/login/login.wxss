.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 60%, #f5f5f5 100%);
  padding: 60rpx 50rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.logo-icon { font-size: 60rpx; }

.app-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 10rpx;
}

.form-area {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.1);
}

.input-group {
  margin-bottom: 30rpx;
}

.input {
  width: 100%;
  height: 90rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
}

.btn-primary {
  margin-top: 20rpx;
}

.switch-mode {
  text-align: center;
  color: #667eea;
  font-size: 26rpx;
  margin-top: 30rpx;
  padding: 10rpx;
}

.footer {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  line-height: 1.8;
}
