.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f0f0;
}

/* 聊天头部 */
.chat-header {
  background: #fff;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #e0e0e0;
}
.header-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.header-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 12rpx;
}

/* 四模式切换器 */
.mode-switcher {
  display: flex;
  gap: 12rpx;
}
.mode-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 8rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}
.mode-option.active {
  background: #f0f0ff;
  border-color: #667eea;
}
.mode-emoji { font-size: 28rpx; }
.mode-label { font-size: 20rpx; color: #666; margin-top: 4rpx; }
.mode-option.active .mode-label { color: #667eea; font-weight: 600; }

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

.message-item {
  margin-bottom: 24rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
}
.mine-row {
  justify-content: flex-end;
}

.msg-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}
.msg-avatar.real { background: #E8F5E9; }
.msg-avatar.twin { background: #F3E5F5; }

.msg-content-wrap {
  margin: 0 16rpx;
  max-width: 65%;
}
.mine-wrap { text-align: right; }

.msg-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}
.mine-meta { justify-content: flex-end; }
.msg-sender { font-size: 22rpx; color: #999; }

.msg-bubble {
  display: inline-block;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-all;
  text-align: left;
}
.other-bubble {
  background: #fff;
  border-top-left-radius: 6rpx;
}
.mine-bubble {
  background: #667eea;
  color: #fff;
  border-top-right-radius: 6rpx;
}

/* 模式切换标注 */
.mode-indicator {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin: 16rpx 0;
}

.message-end { height: 20rpx; }

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #e0e0e0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.current-mode-indicator {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 10rpx 16rpx;
  border-radius: 20rpx;
}
.mode-emoji-small { font-size: 28rpx; }

.msg-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  color: #ccc;
  font-size: 28rpx;
  font-weight: 600;
  padding: 10rpx 20rpx;
}
.send-btn.active { color: #667eea; }
