.contacts-page { padding-bottom: 120rpx; }

/* 身份栏 */
.identity-bar {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.identity-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 20rpx;
}
.identity-avatar.real { background: rgba(76,175,80,0.3); border: 3rpx solid #4CAF50; }
.identity-avatar.twin { background: rgba(156,39,176,0.3); border: 3rpx solid #CE93D8; }

.identity-info { flex: 1; }
.identity-name { font-size: 34rpx; font-weight: 600; display: block; }

.switch-btn {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.2);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}
.switch-text { font-size: 24rpx; margin-right: 8rpx; }
.switch-arrow { font-size: 32rpx; }

/* 搜索 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  margin-bottom: 2rpx;
}
.search-input {
  flex: 1;
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}
.search-btn {
  margin-left: 16rpx;
  color: #667eea;
  font-size: 28rpx;
  font-weight: 600;
  padding: 10rpx 20rpx;
}

/* 分组 */
.section {
  background: #fff;
  margin-top: 20rpx;
  padding: 20rpx 30rpx;
}
.section-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: block;
}

/* 好友项 */
.friend-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.friend-item:last-child { border-bottom: none; }

.friend-avatar-group {
  display: flex;
  margin-right: 20rpx;
}
.friend-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.friend-avatar.small { width: 64rpx; height: 64rpx; font-size: 28rpx; }
.friend-avatar.real { background: #E8F5E9; }
.friend-avatar.twin { background: #F3E5F5; }
.friend-avatar.overlap { margin-left: -20rpx; }

.friend-info { flex: 1; }
.friend-name { font-size: 30rpx; font-weight: 500; display: block; margin-bottom: 6rpx; }
.friend-status { font-size: 24rpx; color: #999; }

.chat-arrow { font-size: 40rpx; color: #ccc; }

/* 操作按钮 */
.action-btns { display: flex; gap: 16rpx; }
.accept-btn {
  background: #667eea;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}
.reject-btn {
  background: #f0f0f0;
  color: #999;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: #999; }
.empty-hint { font-size: 24rpx; color: #ccc; margin-top: 10rpx; }
