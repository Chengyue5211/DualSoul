/* 全局样式 */
page {
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  background: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 30rpx;
}

/* 主题色 */
.primary-bg { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.primary-color { color: #667eea; }

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  width: 100%;
}

.btn-primary::after { border: none; }

/* 身份标记 */
.mode-badge {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  color: #fff;
}
.mode-badge.real { background: #4CAF50; }
.mode-badge.twin { background: #9C27B0; }

/* AI标记 */
.ai-tag {
  display: inline-block;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  background: #FF9800;
  color: #fff;
  margin-left: 8rpx;
}
